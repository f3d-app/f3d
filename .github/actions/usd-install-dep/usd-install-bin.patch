From 3c543b76c6faf52b44801ee32ba2beeb973c2464 Mon Sep 17 00:00:00 2001
From: Mathieu Westphal <mathieu.westphal@kitware.com>
Date: Thu, 21 May 2026 13:49:13 +0200
Subject: [PATCH] [PATCH] install-bin

---
 cmake/macros/Private.cmake | 11 ++++++-----
 cmake/macros/Public.cmake  |  5 +++--
 2 files changed, 9 insertions(+), 7 deletions(-)

diff --git a/cmake/macros/Private.cmake b/cmake/macros/Private.cmake
index e2dccb075..9f1dd3176 100644
--- a/cmake/macros/Private.cmake
+++ b/cmake/macros/Private.cmake
@@ -1273,6 +1273,7 @@ function(_pxr_library NAME)
     _get_install_dir("include" headerInstallDir)
     _get_install_dir("include/${PXR_PREFIX}/${NAME}" headerInstallPrefix)
     _get_install_dir("lib" libInstallPrefix)
+    _get_install_dir("bin" binInstallPrefix)
     if(isPlugin)
         if(NOT isObject)
             # A plugin embedded in the monolithic library is found in
@@ -1465,12 +1466,12 @@ function(_pxr_library NAME)
                 TARGETS ${NAME}
                 LIBRARY DESTINATION ${libInstallPrefix}
                 ARCHIVE DESTINATION ${libInstallPrefix}
-                RUNTIME DESTINATION ${libInstallPrefix}
+                RUNTIME DESTINATION ${binInstallPrefix}
             )
             if(WIN32)
                 install(
                     FILES $<TARGET_PDB_FILE:${NAME}>
-                    DESTINATION ${libInstallPrefix}
+                    DESTINATION ${binInstallPrefix}
                     OPTIONAL
                 )
             endif()
@@ -1480,13 +1481,13 @@ function(_pxr_library NAME)
                 EXPORT pxrTargets
                 LIBRARY DESTINATION ${libInstallPrefix}
                 ARCHIVE DESTINATION ${libInstallPrefix}
-                RUNTIME DESTINATION ${libInstallPrefix}
+                RUNTIME DESTINATION ${binInstallPrefix}
             )
             if(WIN32)
                 install(
                     FILES $<TARGET_PDB_FILE:${NAME}>
                     EXPORT pxrTargets
-                    DESTINATION ${libInstallPrefix}
+                    DESTINATION ${binInstallPrefix}
                     OPTIONAL
                 )
             endif()
@@ -1496,7 +1497,7 @@ function(_pxr_library NAME)
                 EXPORT pxrTargets
                 LIBRARY DESTINATION ${libInstallPrefix}
                 ARCHIVE DESTINATION ${libInstallPrefix}
-                RUNTIME DESTINATION ${libInstallPrefix}
+                RUNTIME DESTINATION ${binInstallPrefix}
             )
         endif()
     
diff --git a/cmake/macros/Public.cmake b/cmake/macros/Public.cmake
index b51789f4a..d7caf83db 100644
--- a/cmake/macros/Public.cmake
+++ b/cmake/macros/Public.cmake
@@ -1197,17 +1197,18 @@ function(pxr_toplevel_prologue)
                     OUTPUT_NAME ${libName}
             )
             _get_install_dir("lib" libInstallPrefix)
+            _get_install_dir("bin" binInstallPrefix)
             install(
                 TARGETS usd_m
                 EXPORT pxrTargets
                 LIBRARY DESTINATION ${libInstallPrefix}
                 ARCHIVE DESTINATION ${libInstallPrefix}
-                RUNTIME DESTINATION ${libInstallPrefix}
+                RUNTIME DESTINATION ${binInstallPrefix}
             )
             if(WIN32 AND BUILD_SHARED_LIBS)
                 install(
                     FILES $<TARGET_PDB_FILE:usd_m>
-                    DESTINATION ${libInstallPrefix}
+                    DESTINATION ${binInstallPrefix}
                     OPTIONAL
                 )
             endif()
-- 
2.54.0

