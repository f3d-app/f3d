{
  "scene": {
    "up_direction": {
      "type": "direction",
      "default_value": "0,1,0"
    },
    "animation": {
      "autoplay": {
        "type": "bool",
        "default_value": "false"
      },
      "index": {
        "type": "int",
        "default_value": "0",
        "deprecated": "use scene.animation.indices instead"
      },
      "indices": {
        "type": "int_vector",
        "default_value": "0"
      },
      "speed_factor": {
        "type": "ratio",
        "default_value": "1.0",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "2.0",
          "increment": "0.1"
        }
      }
    },
    "camera": {
      "index": {
        "type": "int",
        "domain": {
          "style": "index"
        }
      },
      "orthographic": {
        "type": "bool"
      }
    },
    "force_reader": {
      "type": "string"
    }
  },
  "render": {
    "show_edges": {
      "type": "bool"
    },
    "line_width": {
      "type": "double",
      "domain": {
        "style": "range",
        "min": "0.0",
        "max": "10.0",
        "increment": "0.1"
      }
    },
    "point_size": {
      "type": "double",
      "domain": {
        "style": "range",
        "min": "0.0",
        "max": "10.0",
        "increment": "0.1"
      }
    },
    "backface_type": {
      "type": "string",
      "domain": {
        "style": "enum",
        "enum": ["visible", "hidden"]
      }
    },
    "grid": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "absolute": {
        "type": "bool",
        "default_value": "false"
      },
      "unit": {
        "type": "double"
      },
      "subdivisions": {
        "type": "int",
        "default_value": "10"
      },
      "color": {
        "type": "color",
        "default_value": "0.0, 0.0, 0.0"
      },
      "reflection": {
        "type": "ratio",
        "default_value": "0.0"
      }
    },
    "axes_grid": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      }
    },
    "raytracing": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "denoise": {
        "type": "bool",
        "default_value": "false"
      },
      "samples": {
        "type": "int",
        "default_value": "5",
        "domain": {
          "style": "range",
          "min": "1",
          "max": "50",
          "increment": "1"
        }
      }
    },
    "effect": {
      "blending": {
        "mode": {
          "type": "string",
          "default_value": "none",
          "domain": {
            "style": "enum",
            "enum": ["none", "ddp", "sort", "sort_cpu", "stochastic"]
          }
        }
      },
      "antialiasing": {
        "mode": {
          "type": "string",
          "default_value": "none",
          "domain": {
            "style": "enum",
            "enum": ["none", "fxaa", "ssaa", "taa"]
          }
        }
      },
      "ambient_occlusion": {
        "type": "bool",
        "default_value": "false"
      },
      "tone_mapping": {
        "type": "bool",
        "default_value": "false"
      },
      "final_shader": {
        "type": "string"
      },
      "display_depth": {
        "type": "bool",
        "default_value": "false"
      }
    },
    "hdri": {
      "file": {
        "type": "path"
      },
      "ambient": {
        "type": "bool",
        "default_value": "false"
      }
    },
    "background": {
      "color": {
        "type": "color",
        "default_value": "0.2, 0.2, 0.2"
      },
      "skybox": {
        "type": "bool",
        "default_value": "false"
      },
      "blur": {
        "enable": {
          "type": "bool",
          "default_value": "false"
        },
        "coc": {
          "type": "double",
          "default_value": "20.0",
          "domain": {
            "style": "range",
            "min": "0.0",
            "max": "100.0",
            "increment": "5.0"
          }
        }
      }
    },
    "light": {
      "intensity": {
        "type": "double",
        "default_value": "1.0",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "5.0",
          "increment": "0.02"
        }
      }
    },
    "armature": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      }
    }
  },
  "ui": {
    "backdrop": {
      "opacity": {
        "type": "double",
        "default_value": "0.9",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "1.0",
          "increment": "0.05"
        }
      },
      "color": {
        "type": "color",
        "parsed_default_value": "f3d_black"
      }
    },
    "axis": {
      "type": "bool",
      "default_value": "false"
    },
    "x_color": {
      "type": "color",
      "parsed_default_value": "f3d_red"
    },
    "y_color": {
      "type": "color",
      "parsed_default_value": "f3d_green"
    },
    "z_color": {
      "type": "color",
      "parsed_default_value": "f3d_blue"
    },
    "scalar_bar": {
      "type": "bool",
      "default_value": "false"
    },
    "filename": {
      "type": "bool",
      "default_value": "false"
    },
    "filename_info": {
      "type": "string",
      "default_value": ""
    },
    "fps": {
      "type": "bool",
      "default_value": "false"
    },
    "cheatsheet": {
      "type": "bool",
      "default_value": "false"
    },
    "console": {
      "type": "bool",
      "default_value": "false"
    },
    "minimal_console": {
      "type": "bool",
      "default_value": "false"
    },
    "dropzone": {
      "type": "bool",
      "default_value": "false",
      "deprecated": "use ui.drop_zone.enable instead"
    },
    "dropzone_info": {
      "type": "string",
      "default_value": "",
      "deprecated": "use ui.drop_zone.custom_binds instead"
    },
    "drop_zone": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "info": {
        "type": "string",
        "default_value": "",
        "deprecated": "use ui.drop_zone.custom_binds instead"
      },
      "show_logo": {
        "type": "bool",
        "default_value": "false"
      },
      "custom_binds": {
        "type": "string",
        "default_value": ""
      }
    },
    "metadata": {
      "type": "bool",
      "default_value": "false"
    },
    "hdri_filename": {
      "type": "bool",
      "default_value": "false"
    },
    "font_file": {
      "type": "path"
    },
    "scale": {
      "type": "ratio",
      "default_value": "1.0",
      "domain": {
        "style": "range",
        "min": "0.0",
        "max": "10.0",
        "increment": "0.1"
      }
    },
    "font_color": {
      "type": "color",
      "parsed_default_value": "f3d_white"
    },
    "loader_progress": {
      "type": "bool",
      "default_value": "false"
    },
    "loader_progress_color": {
      "type": "color",
      "parsed_default_value": "f3d_yellow"
    },
    "animation_progress": {
      "type": "string",
      "default_value": "none",
      "domain": {
        "style": "enum",
        "enum": ["none", "default", "advanced"]
      }
    },
    "animation_progress_color": {
      "type": "color",
      "parsed_default_value": "f3d_blue"
    },
    "dpi_aware": {
      "type": "bool",
      "default_value": "false"
    },
    "scene_hierarchy": {
      "type": "bool",
      "default_value": "false"
    },
    "notifications": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "show_bindings": {
        "type": "bool",
        "default_value": "false"
      }
    }
  },
  "model": {
    "matcap": {
      "texture": {
        "type": "path"
      }
    },
    "checkerboard": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      }
    },
    "unlit": {
      "type": "bool"
    },
    "color": {
      "opacity": {
        "type": "double",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "1.0",
          "increment": "0.05"
        }
      },
      "rgb": {
        "type": "color"
      },
      "texture": {
        "type": "path"
      }
    },
    "emissive": {
      "factor": {
        "type": "color"
      },
      "texture": {
        "type": "path"
      }
    },
    "normal": {
      "scale": {
        "type": "double",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "3.0",
          "increment": "0.1"
        }
      },
      "texture": {
        "type": "path"
      }
    },
    "material": {
      "metallic": {
        "type": "double",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "1.0",
          "increment": "0.05"
        }
      },
      "roughness": {
        "type": "double",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "1.0",
          "increment": "0.05"
        }
      },
      "base_ior": {
        "type": "double",
        "domain": {
          "style": "range",
          "min": "1.0",
          "max": "2.5",
          "increment": "0.1"
        }
      },
      "texture": {
        "type": "path"
      }
    },
    "textures_transform": {
      "type": "transform2d"
    },
    "scivis": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "cells": {
        "type": "bool",
        "default_value": "false"
      },
      "discretization": {
        "type": "int",
        "domain": {
          "style": "range",
          "min": "1",
          "max": "1024",
          "increment": "5"
        }
      },
      "array_name": {
        "type": "string"
      },
      "component": {
        "type": "int",
        "default_value": "-1"
      },
      "colormap": {
        "type": "colormap",
        "default_value": "0.0, 0.0, 0.0, 0.0, 0.4, 0.9, 0.0, 0.0, 0.8, 0.9, 0.9, 0.0, 1.0, 1.0, 1.0, 1.0"
      },
      "opacity_map": {
        "type": "double_vector",
        "default_value": "0.0, 0.0, 1.0, 1.0"
      },
      "range": {
        "type": "double_vector"
      }
    },
    "point_sprites": {
      "type": {
        "type": "string",
        "default_value": "none",
        "domain": {
          "style": "enum",
          "enum": [
            "none",
            "sphere",
            "gaussian",
            "circle",
            "stddev",
            "bound",
            "cross"
          ]
        }
      },
      "size": {
        "type": "double",
        "default_value": 10.0,
        "domain": {
          "style": "range",
          "min": "1",
          "max": "100",
          "increment": "1"
        }
      },
      "absolute_size": {
        "type": "bool",
        "default_value": "false"
      }
    },
    "normal_glyphs": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "scale": {
        "type": "ratio",
        "default_value": "1.0",
        "domain": {
          "style": "range",
          "min": "0.0",
          "max": "10.0",
          "increment": "0.1"
        }
      },
      "color": {
        "type": "color"
      }
    },
    "volume": {
      "enable": {
        "type": "bool",
        "default_value": "false"
      },
      "inverse": {
        "type": "bool",
        "default_value": "false"
      }
    }
  },
  "interactor": {
    "style": {
      "type": "string",
      "default_value": "default",
      "domain": {
        "style": "enum",
        "enum": ["default", "trackball", "2d"]
      }
    },
    "trackball": {
      "type": "bool",
      "default_value": "false",
      "deprecated": "use interactor.style instead"
    },
    "invert_zoom": {
      "type": "bool",
      "default_value": "false"
    }
  }
}
