[
  {
    "match-type": "glob",
    "match": "*.{las,laz,bpf,bin}",
    "options": {
      "coloring-array": "NormalizedColor",
      "coloring-component": "-2",
      "load-plugins": "pdal",
      "point-size": "5",
      "scalar-coloring": true,
      "up": "+Z"
    }
  },
  {
    "match-type": "glob",
    "match": "*.csd",
    "options": {
      "load-plugins": "pdal",
      "point-size": "5",
      "scalar-coloring": true,
      "up": "+Y"
    }
  }
]
