[
  {
    "match-type": "glob",
    "match": "*.{las,laz,bpf,bin,pcd,ptx}",
    "options": {
      "coloring-array": "NormalizedColor",
      "coloring-component": "-2",
      "load-plugins": "pdal",
      "scalar-coloring": true,
      "up": "+Z"
    }
  },
  {
    "match-type": "glob",
    "match": "*.{sbet}",
    "options": {
      "load-plugins": "pdal",
      "scalar-coloring": true,
      "up": "+Z"
    }
  },
  {
    "match-type": "glob",
    "match": "*.slpk",
    "options": {
      "load-plugins": "pdal",
      "up": "+Y"
    }
  },
  {
    "match-type": "glob",
    "match": "*.{csd,qi}",
    "options": {
      "load-plugins": "pdal",
      "scalar-coloring": true,
      "up": "+Y"
    }
  }
]
