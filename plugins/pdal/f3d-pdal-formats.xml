<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/vnd.laszip">
    <comment>Compressed Lidar point cloud</comment>
    <glob pattern="*.laz"/>
  </mime-type>
  <mime-type type="application/vnd.terrascan.binary">
    <comment>TerraScan binary files</comment>
    <glob pattern="*.bin"/>
  </mime-type>
  <mime-type type="application/vnd.bpf3">
    <comment>Binary Point File</comment>
    <glob pattern="*.bpf"/>
  </mime-type>
</mime-info>
